# =============================================
# ROOT .gitignore — Ayurvedic Supply Chain
# =============================================

# --- SECRETS (NEVER commit these) ---
.env
*.env

# --- Node.js (legacy backend) ---
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# --- Uploaded files (runtime temp storage) ---
uploads/

# --- Java / Maven build output ---
**/target/
*.class
*.jar
*.war

# --- IDE / OS junk ---
.vscode/
.idea/
*.iml
.DS_Store
Thumbs.db

# --- Test keys / scratch files ---
testKey.js
